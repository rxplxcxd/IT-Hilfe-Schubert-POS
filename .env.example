# ==========================================================================
# IT-Hilfe Schubert POS - Umgebungsvariablen
# Kopiere diese Datei zu ".env" (lokal) bzw. trage die Werte bei Vercel ein.
# ==========================================================================

# --- Datenbank (Supabase -> Project Settings -> Database -> Connection string) ---
# WICHTIG: DATABASE_URL nutzt den "Transaction" Pooler (Port 6543) fuer Serverless.
# DIRECT_URL nutzt die direkte Verbindung (Port 5432) fuer Prisma Migrationen.
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:DEIN-DB-PASSWORT@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxx:DEIN-DB-PASSWORT@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# --- Supabase API (Supabase -> Project Settings -> API) ---
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi...DEIN-ANON-KEY"
# Service-Role-Key NUR serverseitig verwenden - niemals im Browser!
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi...DEIN-SERVICE-ROLE-KEY"

# --- Supabase Storage ---
# Name des Storage-Buckets (oeffentlich), den du in Supabase angelegt hast.
SUPABASE_STORAGE_BUCKET="uploads"

# --- Resend (E-Mail Versand) - https://resend.com/api-keys ---
RESEND_API_KEY="re_xxxxxxxxxxxx"
# Absender-Adresse - muss eine bei Resend verifizierte Domain sein.
RESEND_FROM_EMAIL="IT-Hilfe Schubert <rechnung@deine-domain.de>"

# --- Oeffentliche App-URL (fuer Links in E-Mails & Gmail OAuth Redirect) ---
# Lokal: http://localhost:3000  |  Produktion: https://deine-app.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Optional: Gmail-Versand (nur falls du Gmail statt Resend nutzt) ---
GOOGLE_GMAIL_CLIENT_ID=""
GOOGLE_GMAIL_CLIENT_SECRET=""
