generator client {
    provider = "prisma-client-js"
    output   = "../node_modules/.prisma/client"
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
}


model Customer {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  street    String   @default("")
  houseNr   String   @default("")
  zip       String   @default("")
  city      String   @default("")
  phone     String
  email     String   @default("")
  zone      Int      @default(1)
  notes     String   @default("")
  ownerId   Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  invoices  Invoice[]
  subscriptions Subscription[]
  workLogs  WorkLog[]
  devices   DeviceInventory[]
  quotes    Quote[]
  reminders Reminder[]
  orders    Order[]
  tickets   Ticket[]

  @@index([ownerId])
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String   @default("")
  category    String   // FIXED, HOURLY, SUBSCRIPTION
  price       Float
  unit        String   @default("") // e.g. "15 Min", "Monat", "Jahr"
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  invoiceItems InvoiceItem[]
}

model Invoice {
  id            Int      @id @default(autoincrement())
  invoiceNumber String   @unique
  caseNumber    String   @default("") // Unified case number V-YYYY-XXX
  customerId    Int
  customer      Customer @relation(fields: [customerId], references: [id])
  items         InvoiceItem[]
  subtotal      Float    @default(0)
  discount      Float    @default(0)
  travelCost    Float    @default(0)
  total         Float    @default(0)
  paymentMethod String   @default("BAR") // BAR, KARTE
  status        String   @default("OFFEN") // OFFEN, BEZAHLT, STORNIERT
  paidAt        DateTime?
  notes         String   @default("")
  pdfPath       String   @default("")
  emailSentAt   DateTime?
  // Storno fields
  isCancellation     Boolean  @default(false) // true = this IS a Stornorechnung
  cancelsInvoiceId   Int?     // ID of the original invoice this cancels
  cancelledByInvoiceId Int?   // ID of the Stornorechnung that cancelled this
  cancellationReason String   @default("")
  cancelledAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([caseNumber])
  @@index([paidAt])
  @@index([customerId])
}

model InvoiceItem {
  id        Int     @id @default(autoincrement())
  invoiceId Int
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId Int?
  product   Product? @relation(fields: [productId], references: [id])
  name      String
  quantity  Int     @default(1)
  unitPrice Float
  total     Float

  @@index([invoiceId])
}

model Subscription {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])
  type       String   // MONTHLY, YEARLY
  startDate  DateTime @default(now())
  endDate    DateTime?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId, active])
}

model WorkLog {
  id          Int      @id @default(autoincrement())
  customerId  Int
  customer    Customer @relation(fields: [customerId], references: [id])
  invoiceId   Int?
  title       String
  description String   @default("")
  photos      WorkLogPhoto[]
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId])
  @@index([date])
}

model WorkLogPhoto {
  id          Int      @id @default(autoincrement())
  workLogId   Int
  workLog     WorkLog  @relation(fields: [workLogId], references: [id], onDelete: Cascade)
  filePath    String
  fileUrl     String
  isPublic    Boolean  @default(true)
  caption     String   @default("")
  createdAt   DateTime @default(now())
}

model DeviceInventory {
  id          Int      @id @default(autoincrement())
  customerId  Int
  customer    Customer @relation(fields: [customerId], references: [id])
  deviceType  String   @default("") // PC, Laptop, Smartphone, Tablet, Drucker, Router, etc.
  brand       String   @default("")
  model       String   @default("")
  serialNr    String   @default("")
  password    String   @default("")
  wifiPassword String  @default("")
  notes       String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId])
}

model Expense {
  id          Int      @id @default(autoincrement())
  type        String   // EINNAHME, AUSGABE
  category    String   @default("") // Benzin, Hardware, Software, Lizenzen, etc.
  description String   @default("")
  amount      Float
  date        DateTime @default(now())
  reference   String   @default("") // e.g. invoice number or receipt
  ownerId     Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([date])
  @@index([ownerId])
}

model Quote {
  id            Int      @id @default(autoincrement())
  quoteNumber   String   @unique
  caseNumber    String   @default("") // Unified case number V-YYYY-XXX
  customerId    Int
  customer      Customer @relation(fields: [customerId], references: [id])
  items         QuoteItem[]
  subtotal      Float    @default(0)
  discount      Float    @default(0)
  travelCost    Float    @default(0)
  total         Float    @default(0)
  status        String   @default("ENTWURF") // ENTWURF, GESENDET, ANGENOMMEN, ABGELEHNT, STORNIERT
  validUntil    DateTime?
  notes         String   @default("")
  convertedInvoiceId Int?
  emailSentAt   DateTime?
  acceptedAt    DateTime?
  // Storno fields
  cancelledAt        DateTime?
  cancellationReason String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([customerId])
  @@index([caseNumber])
}

model QuoteItem {
  id        Int     @id @default(autoincrement())
  quoteId   Int
  quote     Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId Int?
  name      String
  quantity  Int     @default(1)
  unitPrice Float
  total     Float
}

model Reminder {
  id          Int      @id @default(autoincrement())
  customerId  Int
  customer    Customer @relation(fields: [customerId], references: [id])
  type        String   // FOLLOW_UP, SCHUTZBRIEF_RENEWAL, SECURITY_CHECK, CUSTOM
  title       String
  message     String   @default("")
  dueDate     DateTime
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([dueDate, completed])
  @@index([customerId])
}

model Order {
  id              Int      @id @default(autoincrement())
  orderNumber     String   @unique
  caseNumber      String   @default("") // Unified case number V-YYYY-XXX
  customerId      Int
  customer        Customer @relation(fields: [customerId], references: [id])
  status          String   @default("OFFEN") // OFFEN, IN_BEARBEITUNG, ABGESCHLOSSEN, STORNIERT
  title           String   @default("")
  description     String   @default("")
  // Signature (before job start - liability disclaimer)
  liabilitySignature   String  @default("") // cloud storage ref
  liabilitySigned      Boolean @default(false)
  liabilitySignedAt    DateTime?
  disclaimerText       String  @default("") // saved disclaimer text at time of signing
  customDocuments      String  @default("[]") // JSON array of {name, signed, signedAt}
  // Work phase
  startedAt       DateTime?
  workNotes       String   @default("")
  photos          OrderPhoto[]
  // Completion
  completedAt     DateTime?
  completionNotes String   @default("")
  completionPdfPath    String  @default("") // cloud storage ref for protocol PDF
  handoverSignature    String  @default("") // base64 PNG
  handoverSigned       Boolean @default(false)
  handoverSignedAt     DateTime?
  // Route / trip data
  routeStartType       String  @default("") // gps, manual
  routeStartAddress    String  @default("")
  routeEndAddress      String  @default("")
  routeDistanceKm      Float   @default(0)
  routeDurationMin     Int     @default(0)
  routeCalculatedAt    DateTime?
  // Storno
  cancelledAt          DateTime?
  cancellationReason   String  @default("")
  // Linked invoice
  convertedInvoiceId   Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([customerId])
  @@index([createdAt])
  @@index([caseNumber])
}

model OrderPhoto {
  id          Int      @id @default(autoincrement())
  orderId     Int
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  filePath    String
  fileUrl     String
  isPublic    Boolean  @default(true)
  caption     String   @default("")
  photoType   String   @default("ARBEIT") // VORHER, NACHHER, ARBEIT
  createdAt   DateTime @default(now())
}

model GmailToken {
  id           Int      @id @default(autoincrement())
  // Pro Mitarbeiter ein eigenes Gmail-Token. Der Alt-Datensatz (id=1) bleibt
  // ohne userId erhalten und wird nicht mehr verwendet.
  userId       Int?     @unique
  accessToken  String   @default("")
  refreshToken String   @default("")
  expiresAt    DateTime?
  email        String   @default("")
  updatedAt    DateTime @updatedAt @default(now())
}

model Settings {
  id             Int    @id @default(1)
  companyName    String @default("IT-Hilfe Schubert")
  ownerName      String @default("Leon Schubert")
  street         String @default("")
  zip            String @default("")
  city           String @default("")
  phone          String @default("")
  email          String @default("")
  taxInfo        String @default("Gemäß § 19 UStG wird keine Umsatzsteuer berechnet.")
  invoiceHeader  String @default("")
  logoPath       String @default("")
  logoIsPublic   Boolean @default(true)
  resendApiKey   String @default("")
  bankName       String @default("")
  iban           String @default("")
  bic            String @default("")
  googleClientId     String @default("")
  googleClientSecret String @default("")
  // Domain fuer die Firmen-E-Mail-Adressen der Mitarbeiter.
  mailDomain         String @default("ithilfeschubert.xyz")
  // Default disclaimer text for orders
  disclaimerDefaultText String @default("Der Kunde bestätigt, dass ein aktuelles Backup aller relevanten Daten existiert. Für etwaige Datenverluste während der Reparatur/Wartung wird keine Haftung übernommen. Der Kunde trägt das volle Risiko für nicht gesicherte Daten.")
  // Company HQ address for distance calculation
  hqStreet       String @default("Alte Schulstr 4")
  hqZip          String @default("02694")
  hqCity         String @default("Malschwitz")
  // Counter for unified case numbers
  nextCaseNumber Int    @default(1)
  // Counter for cancellation invoices
  nextStornoNumber Int  @default(1)
  // Counter for support tickets
  nextTicketNumber Int  @default(1)
  updatedAt      DateTime @updatedAt @default(now())
}

// Pro-Mitarbeiter fortlaufende Belegnummern (Vorgang + Storno).
// Jeder Mitarbeiter beginnt eigenstaendig bei 0001, damit es keine
// Dopplungen gibt und das Finanzamt Belege je Mitarbeiter nachvollziehen kann.
model EmployeeCounter {
  employeeNo       Int      @id
  nextCaseNumber   Int      @default(1)
  nextStornoNumber Int      @default(1)
  updatedAt        DateTime @updatedAt @default(now())
}

model TimeSlot {
  id          Int      @id @default(autoincrement())
  dayOfWeek   Int      // 0=So, 1=Mo, 2=Di, 3=Mi, 4=Do, 5=Fr, 6=Sa
  startTime   String   // "09:00"
  endTime     String   // "10:00"
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([dayOfWeek, active])
}

model Appointment {
  id            Int      @id @default(autoincrement())
  date          DateTime // Datum des Termins
  startTime     String   // "09:00"
  endTime       String   // "10:00"
  customerName  String
  customerPhone String
  customerEmail String   @default("")
  address       String   @default("")
  description   String   @default("")
  status        String   @default("OFFEN") // OFFEN, BESTAETIGT, ABGESAGT, ERLEDIGT
  notes         String   @default("") // interne Notizen
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([date, status])
  @@index([status])
}

model AppUser {
  id         Int       @id @default(autoincrement())
  email      String    @unique
  name       String    @default("")
  role       String    @default("EMPLOYEE") // ADMIN, EMPLOYEE
  employeeNo Int?      @unique // fortlaufende Mitarbeiternummer (001, 002, ...)
  status     String    @default("PENDING")  // PENDING, APPROVED, REJECTED
  // Persoenliche Kontaktdaten des Mitarbeiters (erscheinen auf seinen Belegen).
  // Leer = globale Firmendaten aus Settings werden verwendet.
  contactStreet String @default("")
  contactZip    String @default("")
  contactCity   String @default("")
  contactPhone  String @default("")
  // Lokaler Teil der Firmen-E-Mail-Adresse dieses Mitarbeiters, z.B. "leon"
  // -> ergibt zusammen mit Settings.mailDomain "leon@ithilfeschubert.xyz".
  emailPrefix   String @default("")
  // ---- Erweiterte Personaldaten (Mitarbeiterverwaltungszentrale) ----
  position         String    @default("") // Funktion/Rolle im Betrieb
  personalEmail    String    @default("") // private E-Mail
  birthDate        DateTime?
  startDate        DateTime?              // Eintrittsdatum
  emergencyContact String    @default("") // Notfallkontakt Name
  emergencyPhone   String    @default("") // Notfallkontakt Telefon
  iban             String    @default("") // fuer Lohn
  taxId            String    @default("") // Steuer-ID
  socialSecurityNo String    @default("") // Sozialversicherungsnummer
  healthInsurance  String    @default("") // Krankenkasse
  // ---- Erweiterte Personalstammdaten (Finanzamt / Lohnbuchhaltung) ----
  birthPlace       String    @default("") // Geburtsort
  nationality      String    @default("") // Staatsangehoerigkeit
  maritalStatus    String    @default("") // ledig, verheiratet, geschieden, verwitwet
  religion         String    @default("") // Konfession (Kirchensteuer)
  taxClass         String    @default("") // Steuerklasse I-VI
  childAllowances  Float?                 // Kinderfreibetraege
  severelyDisabled Boolean   @default(false) // Schwerbehinderung
  employmentType   String    @default("") // MINIJOB, TEILZEIT, VOLLZEIT, WERKSTUDENT, AUSBILDUNG
  weeklyHours      Float?                 // Wochenarbeitszeit (Stunden)
  hourlyWage       Float?                 // Stundenlohn (brutto)
  monthlySalary    Float?                 // Monatsgehalt (brutto)
  vacationDays     Int?                   // Urlaubsanspruch pro Jahr
  exitDate         DateTime?              // Austrittsdatum
  employmentStatus String    @default("AKTIV") // AKTIV, INAKTIV, AUSGESCHIEDEN
  internalNotes    String    @default("") // interne Notizen (nur Admin)
  // ---- Einladung & Vertrag (Phase B) ----
  inviteToken      String?   @unique          // kryptografisches Einladungs-Token
  inviteExpiresAt  DateTime?                  // Ablauf des Einladungs-Links
  contractSignature String   @default("")     // Base64-PNG der Unterschrift
  contractSignedAt DateTime?                  // Zeitpunkt der Vertragsunterschrift
  // ---- Onboarding / Gating ----
  onboardingDone   Boolean   @default(false)
  // Persoenliche Konfiguration des Start-Hero-Widgets (JSON-String):
  // { modules: [{ id, enabled }] } in gewuenschter Reihenfolge. Leer = Standard.
  dashboardConfig  String    @default("")
  approvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt @default(now())
  documents  EmployeeDocument[]

  @@index([status])
}

model EmployeeDocument {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   String   @default("SONSTIGES") // VERTRAG, VERSICHERUNG, AUSWEIS, ZEUGNIS, SONSTIGES
  fileName   String
  filePath   String   @default("") // cloud_storage_path (privat)
  isPublic   Boolean  @default(false)
  mimeType   String   @default("")
  size       Int      @default(0)
  expiryDate DateTime? // Ablaufdatum (z.B. Fuehrerschein, Aufenthaltstitel, Zertifikat)
  uploadedAt DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  actorId   Int?     // AppUser-ID des Ausloesers
  actorName String   @default("")
  action    String   // CREATE, UPDATE, DELETE, APPROVE, REJECT, ROLE, PREFIX ...
  entity    String   // USER, DEVICE, DOCUMENT ...
  entityId  Int?
  summary   String   @default("")
  details   String   @default("") // optionales JSON
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}

model Ticket {
  id            Int      @id @default(autoincrement())
  ticketNumber  String   @unique
  subject       String
  description   String   @default("")
  status        String   @default("OFFEN") // OFFEN, IN_BEARBEITUNG, ERLEDIGT
  priority      String   @default("NORMAL") // NIEDRIG, NORMAL, HOCH
  category      String   @default("SONSTIGES") // HARDWARE, SOFTWARE, NETZWERK, ABRECHNUNG, KUNDE, TERMIN, ZUGANG, APP, MATERIAL, SONSTIGES
  createdById   Int
  createdByName String   @default("")
  createdByNo   Int?
  customerId    Int?
  customer      Customer? @relation(fields: [customerId], references: [id])
  adminUnread   Boolean  @default(true)
  employeeUnread Boolean @default(false)
  dueDate       DateTime?
  reminderStage Int      @default(0) // 0=keine, 1=3T, 2=1T, 3=1h, 4=ueberfaellig gesendet
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt @default(now())
  closedAt      DateTime?
  attachments   TicketAttachment[]
  messages      TicketMessage[]

  @@index([createdById])
  @@index([status])
  @@index([customerId])
}

model TicketAttachment {
  id        Int      @id @default(autoincrement())
  ticketId  Int
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  url       String
  filePath  String   @default("")
  kind      String   @default("image") // image, video
  caption   String   @default("")
  createdAt DateTime @default(now())

  @@index([ticketId])
}

model TicketMessage {
  id         Int      @id @default(autoincrement())
  ticketId   Int
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   Int
  authorName String   @default("")
  authorRole String   @default("EMPLOYEE") // ADMIN, EMPLOYEE
  body       String
  attachments String  @default("[]") // JSON-Array: [{url, filePath, kind, caption}]
  createdAt  DateTime @default(now())

  @@index([ticketId])
}
